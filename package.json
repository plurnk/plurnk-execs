{
    "name": "@plurnk/plurnk-execs",
    "version": "0.4.18",
    "description": "Framework + contract for the @plurnk/plurnk-execs-* runtime executor family.",
    "keywords": [
        "plurnk",
        "exec",
        "runtime",
        "executor"
    ],
    "homepage": "https://github.com/plurnk/plurnk-execs#readme",
    "bugs": {
        "url": "https://github.com/plurnk/plurnk-execs/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/plurnk/plurnk-execs.git"
    },
    "engines": {
        "node": ">=26"
    },
    "license": "MIT",
    "author": "@wikitopian",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md",
        "SPEC.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test \"src/**/*.test.ts\"",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build"
    },
    "dependencies": {
        "@plurnk/plurnk-schemes": "^0.29.13"
    },
    "devDependencies": {
        "@types/node": "^26.0.0",
        "typescript": "^6.0.3"
    }
}
